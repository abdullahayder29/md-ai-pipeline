/*
================================================================================
  NEXTFLOW CONFIGURATION FILE
================================================================================
  This file is the "control panel" for the pipeline. It NEVER contains
  scientific logic — only infrastructure configuration. This separation
  is a core Nextflow design principle.

  WHY THIS MATTERS:
  The same main.nf can run on a laptop, a university HPC cluster, or AWS
  simply by changing this config file (or using a different profile).
  The pipeline logic never needs to change.

  KEY CONCEPT — Profiles:
  Profiles are named configurations for different environments. You activate
  them at runtime with the `-profile` flag:
    nextflow run main.nf -profile gpu_local
    nextflow run main.nf -profile slurm
================================================================================
*/

// ─────────────────────────────────────────────────────────────────────────────
// PROCESS DEFAULTS
// These settings apply to ALL processes unless overridden by a label or profile.
// ─────────────────────────────────────────────────────────────────────────────
process {
    // Default resource allocation for lightweight processes
    cpus   = 4
    memory = '8 GB'
    time   = '2h'

    // Default error handling:
    // 'retry' — Nextflow will automatically retry failed jobs (useful for HPC
    //            where jobs can fail due to transient infrastructure errors)
    errorStrategy = 'retry'
    maxRetries    = 2

    // ── RESOURCE LABELS ──────────────────────────────────────────────────────
    // Labels map to specific resource profiles. In main.nf, we use `label 'gpu'`
    // for the PRODUCTION_MD process. Nextflow looks up the matching withLabel block.

    withLabel: 'gpu' {
        // High-resource allocation for the MD simulation process
        cpus         = 16
        memory       = '64 GB'
        time         = '48h'
        // GPU acceleration: request 1 GPU
        // The exact syntax depends on your execution environment (see profiles below)
        accelerator  = [request: 1, type: 'nvidia-tesla-v100']
    }

    withLabel: 'high_cpu' {
        cpus   = 32
        memory = '128 GB'
        time   = '24h'
    }

    withLabel: 'low_mem' {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
    }
}


// ─────────────────────────────────────────────────────────────────────────────
// EXECUTION PROFILES
// Each profile block configures a complete execution environment.
// ─────────────────────────────────────────────────────────────────────────────
profiles {

    // ── PROFILE: standard ────────────────────────────────────────────────────
    // Default profile for local execution on a workstation/laptop.
    // Usage: nextflow run main.nf  (no -profile flag needed, this is the default)
    standard {
        process.executor = 'local'

        // Conda is the recommended package manager for bioinformatics pipelines.
        // With this enabled, Nextflow AUTOMATICALLY creates conda environments
        // from the `conda` directives in each process — you don't need to activate
        // anything manually.
        conda.enabled    = true
        conda.useMamba   = true    // Mamba is a faster conda solver; use if available
    }

    // ── PROFILE: gpu_local ───────────────────────────────────────────────────
    // For a local workstation with one or more NVIDIA GPUs.
    // Usage: nextflow run main.nf -profile gpu_local
    gpu_local {
        process.executor = 'local'
        conda.enabled    = true
        conda.useMamba   = true

        process {
            withLabel: 'gpu' {
                // Override the resource label for local GPU (no scheduler needed)
                cpus   = 8
                memory = '32 GB'
                time   = '72h'
                // For local execution, GPU is controlled by CUDA_VISIBLE_DEVICES
                // Set this in your environment before running the pipeline
            }
        }
    }

    // ── PROFILE: slurm ───────────────────────────────────────────────────────
    // For HPC clusters using the SLURM workload manager.
    // Nextflow submits EACH PROCESS as an independent SLURM job.
    // Usage: nextflow run main.nf -profile slurm
    slurm {
        process.executor = 'slurm'
        conda.enabled    = true

        process {
            // Default SLURM settings for all processes
            queue        = 'general'
            clusterOptions = '--account=my_project_account'  // Change to your HPC account

            // Override settings for GPU-labeled processes
            withLabel: 'gpu' {
                queue          = 'gpu'           // GPU partition name on your cluster
                clusterOptions = '--account=my_project_account --gres=gpu:1'
                cpus           = 16
                memory         = '64 GB'
                time           = '48h'
            }
        }
    }

    // ── PROFILE: docker ──────────────────────────────────────────────────────
    // For fully containerized execution. Ensures 100% reproducibility.
    // Usage: nextflow run main.nf -profile docker
    docker {
        process.executor = 'local'
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'

        // Map each conda environment to a Docker image
        process {
            withName: 'PREPARE_SYSTEM|PRODUCTION_MD|PROCESS_TRAJECTORY' {
                container = 'gromacs/gromacs:2023.3'
            }
            withName: 'AI_ANALYSIS' {
                container = 'pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime'
            }
        }
    }

    // ── PROFILE: test ────────────────────────────────────────────────────────
    // Minimal configuration for fast CI/CD testing and pipeline validation.
    // Overrides parameters to use tiny test data.
    // Usage: nextflow run main.nf -profile test
    test {
        process.executor = 'local'
        conda.enabled    = true

        params {
            pdb_file   = "${projectDir}/data/test/small_peptide.pdb"
            sim_time   = 0.1         // 0.1 ns — fast test run
            n_epochs   = 10          // Quick training
            batch_size = 16
        }

        process {
            cpus   = 2
            memory = '4 GB'
            time   = '30m'
        }
    }
}


// ─────────────────────────────────────────────────────────────────────────────
// PIPELINE METADATA
// ─────────────────────────────────────────────────────────────────────────────
manifest {
    name            = 'md-ai-pipeline'
    author          = 'Your Name'
    description     = 'Nextflow-orchestrated MD simulation + PyTorch conformational analysis'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'    // Minimum Nextflow version required
    mainScript      = 'main.nf'
}


// ─────────────────────────────────────────────────────────────────────────────
// REPORTING & TRACING
// Nextflow can automatically generate HTML reports on every run.
// These are invaluable for debugging, benchmarking, and sharing results.
// ─────────────────────────────────────────────────────────────────────────────
report {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_trace.txt"
    overwrite = true
    // Include detailed resource usage for each process
    fields    = 'task_id,hash,name,status,exit,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_dag.html"
    overwrite = true
}


// ─────────────────────────────────────────────────────────────────────────────
// CONDA CACHING
// Tell Nextflow WHERE to store conda environments so they are reused
// across runs instead of being rebuilt every time. This saves significant time.
// ─────────────────────────────────────────────────────────────────────────────
conda {
    cacheDir = "${HOME}/.nextflow/conda_envs"
}
